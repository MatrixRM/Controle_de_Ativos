<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="Python FastCGI"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\Users\roberto.manica\Desktop\ativos\Controle_de_Ativos\env\Scripts\python.exe|C:\Users\roberto.manica\Desktop\ativos\Controle_de_Ativos\env\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script"/>
    </handlers>
  </system.webServer>
  <appSettings>
    <add key="WSGI_HANDLER" value="django.core.wsgi.get_wsgi_application()" />
    <add key="PYTHONPATH" value="C:\Users\roberto.manica\Desktop\ativos\Controle_de_Ativos" />
    <add key="DJANGO_SETTINGS_MODULE" value="ativos.settings" />
  </appSettings>
</configuration>
